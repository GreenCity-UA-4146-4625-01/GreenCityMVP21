<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">
    <changeSet id="2-create-event_event_types-table" author="Taras Fedchyshyn">
        <createTable tableName="event_event_types">
            <column name="event_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_event_types_event" references="events(id)"/>
            </column>
            <column name="event_type" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="event_event_types"/>
        </rollback>
    </changeSet>

</databaseChangeLog>