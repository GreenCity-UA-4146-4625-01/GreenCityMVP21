<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">
    <changeSet id="3-create-event_date_times-table" author="Taras Fedchyshyn">
        <createTable tableName="event_date_times">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_event_date_times_event" references="events(id)"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="start_time" type="TIME"/>
            <column name="end_time" type="TIME"/>
            <column name="all_day" type="BOOLEAN" defaultValueBoolean="false"/>
        </createTable>
        <rollback>
            <dropTable tableName="event_date_times"/>
        </rollback>
    </changeSet>

</databaseChangeLog>