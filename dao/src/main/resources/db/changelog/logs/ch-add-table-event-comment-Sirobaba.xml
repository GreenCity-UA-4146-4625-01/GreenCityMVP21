<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1753219851535-1" author="mykytasirobaba">
        <createTable tableName="event_comment">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_event_comment"/>
            </column>
            <column name="text" type="VARCHAR(8000)">
                <constraints nullable="false"/>
            </column>
            <column name="created_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="modified_date" type="DATETIME">
                <constraints nullable="false"/>
            </column>
            <column name="parent_comment_id" type="BIGINT"/>
            <column name="user_id" type="BIGINT"/>
            <column name="event_id" type="BIGINT"/>
            <column name="is_organizer_reply" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="deleted" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1753219851535-2" author="mykytasirobaba">
        <createTable tableName="event_comment_users_liked">
            <column name="event_comment_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_event_comment_users_liked"/>
            </column>
            <column name="users_liked_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_event_comment_users_liked"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1753219851535-3" author="mykytasirobaba">
        <createTable tableName="event_comment_users_mentioned">
            <column name="event_comment_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_event_comment_users_mentioned"/>
            </column>
            <column name="mentioned_user_id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_event_comment_users_mentioned"/>
            </column>
        </createTable>
    </changeSet>
    <changeSet id="1753219851535-4" author="mykytasirobaba">
        <addForeignKeyConstraint baseColumnNames="event_id" baseTableName="event_comment"
                                 constraintName="FK_EVENT_COMMENT_ON_EVENT" referencedColumnNames="id"
                                 referencedTableName="events"/>
    </changeSet>
    <changeSet id="1753219851535-5" author="mykytasirobaba">
        <addForeignKeyConstraint baseColumnNames="parent_comment_id" baseTableName="event_comment"
                                 constraintName="FK_EVENT_COMMENT_ON_PARENTCOMMENT" referencedColumnNames="id"
                                 referencedTableName="event_comment"/>
    </changeSet>
    <changeSet id="1753219851535-6" author="mykytasirobaba">
        <addForeignKeyConstraint baseColumnNames="user_id" baseTableName="event_comment"
                                 constraintName="FK_EVENT_COMMENT_ON_USER" referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>
    <changeSet id="1753219851535-7" author="mykytasirobaba">
        <addForeignKeyConstraint baseColumnNames="event_comment_id" baseTableName="event_comment_users_liked"
                                 constraintName="fk_evecomuselik_on_event_comment" referencedColumnNames="id"
                                 referencedTableName="event_comment"/>
    </changeSet>
    <changeSet id="1753219851535-8" author="mykytasirobaba">
        <addForeignKeyConstraint baseColumnNames="users_liked_id" baseTableName="event_comment_users_liked"
                                 constraintName="fk_evecomuselik_on_user" referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>
    <changeSet id="1753219851535-9" author="mykytasirobaba">
        <addForeignKeyConstraint baseColumnNames="event_comment_id" baseTableName="event_comment_users_mentioned"
                                 constraintName="fk_evecomusemen_on_event_comment" referencedColumnNames="id"
                                 referencedTableName="event_comment"/>
    </changeSet>
    <changeSet id="1753219851535-10" author="mykytasirobaba">
        <addForeignKeyConstraint baseColumnNames="mentioned_user_id" baseTableName="event_comment_users_mentioned"
                                 constraintName="fk_evecomusemen_on_user" referencedColumnNames="id"
                                 referencedTableName="users"/>
    </changeSet>

</databaseChangeLog>