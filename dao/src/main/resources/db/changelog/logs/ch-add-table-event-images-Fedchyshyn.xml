<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">
    <changeSet id="6-create-event_images-table" author="Taras Fedchyshyn">
        <createTable tableName="event_images">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="url" type="VARCHAR(512)">
                <constraints nullable="false"/>
            </column>
            <column name="is_main" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_event_images_event" references="events(id)"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="event_images"/>
        </rollback>
    </changeSet>

</databaseChangeLog>