<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.4.xsd">
    <changeSet id="4-create-event_locations-table" author="Taras Fedchyshyn">
        <createTable tableName="event_locations">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="address" type="VARCHAR(255)"/>
            <column name="latitude" type="DECIMAL(10,8)"/>
            <column name="longitude" type="DECIMAL(11,8)"/>
            <column name="event_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_event_locations_event" references="events(id)"/>
            </column>
        </createTable>
        <rollback>
            <dropTable tableName="event_locations"/>
        </rollback>
    </changeSet>

</databaseChangeLog>