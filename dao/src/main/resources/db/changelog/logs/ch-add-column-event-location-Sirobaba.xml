<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.25.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <changeSet id="1752432796202-1" author="mykytasirobaba">
        <createTable tableName="event_locations">
            <column autoIncrement="true" name="id" type="BIGINT">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_event_locations"/>
            </column>
            <column name="event_id" type="BIGINT"/>
            <column name="address" type="VARCHAR(255)"/>
            <column name="latitude" type="DOUBLE"/>
            <column name="longitude" type="DOUBLE"/>
        </createTable>
    </changeSet>
    <changeSet id="1752432796202-2" author="mykytasirobaba">
        <addForeignKeyConstraint baseColumnNames="event_id" baseTableName="event_locations"
                                 constraintName="FK_EVENT_LOCATIONS_ON_EVENT" referencedColumnNames="id"
                                 referencedTableName="events"/>
    </changeSet>

</databaseChangeLog>